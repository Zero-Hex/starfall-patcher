		<ScreenID>GCW_SearchLabel</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>240</X><Y>10</Y></Location>
		<Size><CX>50</CX><CY>18</CY></Size>
		<Text>Search:</Text>
		<TextColor><R>255</R><G>255</G><B>255</B></TextColor>
