<?xml version="1.0"?>
<XML ID="EQInterfaceDefinitionLanguage">
	<Schema xmlns="EverQuestData" xmlns:dt="EverQuestDataTypes" />

	<!-- Guild Crafter window: tradeskill picker -> searchable recipe list ->
	     component checklist -> Craft/Train. Opens only in response to the
	     server's GCRAFT|...|end skill snapshot (sent when the player hails the NPC) — there is
	     no toolbar entry and no player-typed show command, unlike Persona/
	     Celestial Bank/Advanced Loot. Same SIDL + WndNotification pattern as
	     every other native window in this repo. Component list color-codes by
	     source: green=vault, light blue=your bags, gold=missing but
	     purchasable (cost shown), red=missing, yellow=no-drop/must carry. -->

	<Listbox item="GCW_SkillList">
		<ScreenID>GCW_SkillList</ScreenID>
		<DrawTemplate>WDT_Inner</DrawTemplate>
		<TooltipReference>Pick a tradeskill to browse its recipes. A green level number means a donated boost is currently raising it above its trained base level.</TooltipReference>
		<RelativePosition>true</RelativePosition>
		<Location><X>10</X><Y>32</Y></Location>
		<Size><CX>220</CX><CY>160</CY></Size>
		<Style_Border>true</Style_Border>
		<Style_VScroll>true</Style_VScroll>
		<Columns><Width>130</Width><Heading>Skill</Heading></Columns>
		<Columns><Width>45</Width><Heading>Lv</Heading></Columns>
		<Columns><Width>45</Width><Heading>Cap</Heading></Columns>
	</Listbox>

