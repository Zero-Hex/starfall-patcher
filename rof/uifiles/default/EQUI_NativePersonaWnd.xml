<?xml version="1.0"?>
<XML ID="EQInterfaceDefinitionLanguage">
	<Schema xmlns="EverQuestData" xmlns:dt="EverQuestDataTypes" />

	<!-- Class icons (WarriorIcon, ClericIcon, "Shadow KnightIcon", etc. — 32
	     of them, one Icon + one DisabledIcon per playable class) are NOT
	     redefined here. They're already declared as Ui2DAnimation items in
	     the base client's EQUI_CharacterCreate.xml (its race/class picker),
	     and SIDL registers Ui2DAnimation names globally across every loaded
	     UI file in the skin, so any window can reference them by name once
	     that file has loaded — which it always has, since character
	     creation is a base screen every client ships. Same for the
	     SelectIcon/HoverIcon overlay decals used as PressedDecal/FlybyDecal
	     below. Confirmed present under these exact names in the RoF2 (May
	     10 2013) client's own EQUI_CharacterCreate.xml. -->

	<Label item="PW_SummaryLabel">
		<ScreenID>PW_SummaryLabel</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>12</X><Y>18</Y></Location>
		<Size><CX>380</CX><CY>20</CY></Size>
		<Text>Active: Warrior (Level 1)</Text>
		<TextColor><R>220</R><G>230</G><B>255</B></TextColor>
		<NoWrap>true</NoWrap>
	</Label>

