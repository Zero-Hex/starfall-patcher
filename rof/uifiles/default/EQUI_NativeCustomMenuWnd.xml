	</Button>

	<Screen item="NativeCustomMenuWnd">
		<ScreenID>NativeCustomMenuWnd</ScreenID>
		<RelativePosition>false</RelativePosition>
		<Location><X>20</X><Y>20</Y></Location>
		<Size><CX>294</CX><CY>224</CY></Size>
		<Text>Starfall EQEMU</Text>
		<DrawTemplate>WDT_Def</DrawTemplate>
		<Style_Titlebar>true</Style_Titlebar>
		<Style_Closebox>false</Style_Closebox>
		<Style_Minimizebox>true</Style_Minimizebox>
		<Style_Border>true</Style_Border>
		<Style_Sizable>false</Style_Sizable>
		<Style_Transparent>false</Style_Transparent>
		<Escapable>false</Escapable>
		<Pieces>CUST_SubtitleLabel</Pieces>
		<Pieces>CUST_AutoLootButton</Pieces>
		<Pieces>CUST_PersonaButton</Pieces>
		<Pieces>CUST_CelestialBankButton</Pieces>
		<Pieces>CUST_AutoskillButton</Pieces>
		<Pieces>CUST_AutospellButton</Pieces>
		<Pieces>CUST_FactionButton</Pieces>
		<Pieces>CUST_AchievementsButton</Pieces>
		<Pieces>CUST_CollectionsButton</Pieces>
		<Pieces>CUST_PetButton</Pieces>
		<Pieces>CUST_ChatTimestampsButton</Pieces>
	</Screen>

</XML>
