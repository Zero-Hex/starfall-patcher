<?xml version="1.0"?>
<XML ID="EQInterfaceDefinitionLanguage">
	<Schema xmlns="EverQuestData" xmlns:dt="EverQuestDataTypes" />

	<!-- Custom quick-launch bar: one-click access to the Starfall native
	     windows (Advanced Loot, Persona, Celestial Bank). There is no editable
	     client resource for the built-in EQ-button cascade menu, so this is a
	     small always-visible native window instead — same SIDL + WndNotification
	     pattern as EQUI_NativePersonaWnd.xml / EQUI_NativeCelestialBankWnd.xml.
	     Each button is a one-click open/close TOGGLE (see custom_menu_feature.cpp);
	     gold accent color ties this window's branding to the multi-select
	     highlight used in the Celestial Bank window.

	     Two columns: column 1 (X=8) holds Advanced Loot/Persona/Celestial
	     Bank/Autoskill/Autospell/Factions; column 2 (X=152) starts fresh with
	     Achievements/Collections/Pets/Timestamps. Column 1 is taller (6 rows)
	     than column 2 (4 rows), so the window's overall height is sized to
	     column 1. -->

	<Label item="CUST_SubtitleLabel">
		<ScreenID>CUST_SubtitleLabel</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>8</X><Y>18</Y></Location>
		<Size><CX>134</CX><CY>16</CY></Size>
		<Text>Quick Launch</Text>
		<TextColor><R>255</R><G>204</G><B>51</B></TextColor>
		<NoWrap>true</NoWrap>
	</Label>

	<Button item="CUST_AutoLootButton">
		<ScreenID>CUST_AutoLootButton</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>8</X><Y>38</Y></Location>
		<Size><CX>134</CX><CY>22</CY></Size>
		<Text>Advanced Loot</Text>
		<TextColor><R>255</R><G>204</G><B>51</B></TextColor>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>false</Style_Checkbox>
		<Template>BDT_Normal</Template>
		<TooltipReference>Open/close the Advanced Loot window</TooltipReference>
	</Button>

	<Button item="CUST_PersonaButton">
		<ScreenID>CUST_PersonaButton</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>8</X><Y>64</Y></Location>
		<Size><CX>134</CX><CY>22</CY></Size>
		<Text>Persona</Text>
		<TextColor><R>255</R><G>204</G><B>51</B></TextColor>
