		<RelativePosition>true</RelativePosition>
		<Location><X>8</X><Y>90</Y></Location>
		<Size><CX>134</CX><CY>22</CY></Size>
		<Text>Celestial Bank</Text>
		<TextColor><R>255</R><G>204</G><B>51</B></TextColor>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>false</Style_Checkbox>
		<Template>BDT_Normal</Template>
		<TooltipReference>Open/close the Celestial Bank window</TooltipReference>
	</Button>

