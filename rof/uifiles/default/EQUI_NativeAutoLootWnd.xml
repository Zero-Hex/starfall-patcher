<?xml version="1.0"?>
<XML ID="EQInterfaceDefinitionLanguage">
	<Schema xmlns="EverQuestData" xmlns:dt="EverQuestDataTypes" />

	<Label item="AALW_PersonalLabel">
		<ScreenID>AALW_PersonalLabel</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>8</X><Y>18</Y></Location>
		<Size><CX>180</CX><CY>18</CY></Size>
		<Text>Personal Loot</Text>
		<TextColor><R>190</R><G>210</G><B>230</B></TextColor>
		<NoWrap>true</NoWrap>
	</Label>

	<!-- NOTE: the list, bottom buttons, and status label are deliberately
	     plain-positioned (no anchors/AutoStretch): the client re-applies SIDL
	     anchors on every resize, which fights the DLL's own reflow. The DLL
	     lays these pieces out on window resize (see loot_window.cpp). -->
	<Listbox item="AALW_PersonalList">
		<ScreenID>AALW_PersonalList</ScreenID>
		<DrawTemplate>WDT_Inner</DrawTemplate>
		<RelativePosition>true</RelativePosition>
		<Location><X>8</X><Y>38</Y></Location>
		<Size><CX>624</CX><CY>234</CY></Size>
		<Style_Border>true</Style_Border>
		<Style_VScroll>true</Style_VScroll>
		<Font>3</Font>
		<Columns><Width>20</Width><Heading></Heading></Columns>
		<Columns><Width>200</Width><Heading>Item</Heading></Columns>
		<Columns><Width>42</Width><Heading>Qty</Heading></Columns>
		<Columns><Width>150</Width><Heading>NPC Name</Heading></Columns>
		<Columns><Width>105</Width><Heading>Sell Value</Heading></Columns>
		<Columns><Width>208</Width><Heading></Heading></Columns>
	</Listbox>

	<!-- Bottom button row: Loot All | Discard All | Refresh | Edit Filters
	     (per-item actions are handled by the floating context buttons on each row) -->
	<Button item="AALW_LootAllButton">
		<ScreenID>AALW_LootAllButton</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>8</X><Y>276</Y></Location>
		<Size><CX>153</CX><CY>22</CY></Size>
		<Text>Loot All</Text>
		<TextColor><R>255</R><G>255</G><B>255</B></TextColor>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>false</Style_Checkbox>
		<Template>BDT_Normal</Template>
	</Button>

	<Button item="AALW_LeaveAllButton">
		<ScreenID>AALW_LeaveAllButton</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>165</X><Y>276</Y></Location>
		<Size><CX>153</CX><CY>22</CY></Size>
		<Text>Discard All</Text>
		<TextColor><R>255</R><G>255</G><B>255</B></TextColor>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>false</Style_Checkbox>
		<Template>BDT_Normal</Template>
	</Button>

	<Button item="AALW_RefreshButton">
		<ScreenID>AALW_RefreshButton</ScreenID>
		<RelativePosition>true</RelativePosition>
