	</Button>

	<Button item="AALW_EditFiltersButton">
		<ScreenID>AALW_EditFiltersButton</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>479</X><Y>276</Y></Location>
		<Size><CX>153</CX><CY>22</CY></Size>
		<Text>Edit Filters</Text>
		<TextColor><R>255</R><G>255</G><B>255</B></TextColor>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>false</Style_Checkbox>
		<Template>BDT_Normal</Template>
	</Button>

	<Label item="AALW_StatusLabel">
		<ScreenID>AALW_StatusLabel</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>8</X><Y>304</Y></Location>
		<Size><CX>624</CX><CY>18</CY></Size>
		<Text>Click any row to show action buttons. Use bottom buttons for batch actions.</Text>
		<TextColor><R>220</R><G>230</G><B>255</B></TextColor>
		<NoWrap>true</NoWrap>
	</Label>

	<!-- Context Button Panel: 5 action buttons that float over the clicked row.
	     All start at (0,0) hidden; the DLL repositions and shows them on each click. -->
	<Button item="AALW_CBP_Loot">
		<ScreenID>AALW_CBP_Loot</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>0</X><Y>0</Y></Location>
		<Size><CX>44</CX><CY>18</CY></Size>
		<Text>Loot</Text>
		<TextColor><R>120</R><G>230</G><B>120</B></TextColor>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>false</Style_Checkbox>
		<Template>BDT_Normal</Template>
		<TooltipReference>Loot this item once</TooltipReference>
	</Button>

	<Button item="AALW_CBP_Discard">
		<ScreenID>AALW_CBP_Discard</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>0</X><Y>0</Y></Location>
		<Size><CX>56</CX><CY>18</CY></Size>
		<Text>Discard</Text>
		<TextColor><R>230</R><G>170</G><B>90</B></TextColor>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>false</Style_Checkbox>
		<Template>BDT_Normal</Template>
		<TooltipReference>Discard this item (sells for vendor value, or destroys it if worthless)</TooltipReference>
	</Button>

	<Button item="AALW_CBP_AlwaysKeep">
		<ScreenID>AALW_CBP_AlwaysKeep</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>0</X><Y>0</Y></Location>
		<Size><CX>52</CX><CY>18</CY></Size>
		<Text>A.Keep</Text>
		<TextColor><R>100</R><G>255</G><B>100</B></TextColor>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>false</Style_Checkbox>
		<Template>BDT_Normal</Template>
		<TooltipReference>Always Keep: add a keep-always rule for this item</TooltipReference>
	</Button>

	<Button item="AALW_CBP_Never">
		<ScreenID>AALW_CBP_Never</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>0</X><Y>0</Y></Location>
		<Size><CX>48</CX><CY>18</CY></Size>
		<Text>Never</Text>
		<TextColor><R>230</R><G>100</G><B>100</B></TextColor>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>false</Style_Checkbox>
		<Template>BDT_Normal</Template>
		<TooltipReference>Never loot: add an ignore rule for this item</TooltipReference>
	</Button>

	<Screen item="NativeAutoLootWnd">
		<ScreenID>NativeAutoLootWnd</ScreenID>
		<RelativePosition>false</RelativePosition>
		<Location><X>80</X><Y>80</Y></Location>
		<Size><CX>640</CX><CY>330</CY></Size>
		<Text>Advanced Loot</Text>
		<DrawTemplate>WDT_Def</DrawTemplate>
		<Style_Titlebar>true</Style_Titlebar>
		<Style_Closebox>true</Style_Closebox>
		<Style_Minimizebox>true</Style_Minimizebox>
		<Style_Border>true</Style_Border>
		<Style_Sizable>true</Style_Sizable>
		<Style_Transparent>false</Style_Transparent>
		<Pieces>AALW_PersonalLabel</Pieces>
		<Pieces>AALW_PersonalList</Pieces>
		<Pieces>AALW_LootAllButton</Pieces>
		<Pieces>AALW_LeaveAllButton</Pieces>
		<Pieces>AALW_RefreshButton</Pieces>
		<Pieces>AALW_EditFiltersButton</Pieces>
		<Pieces>AALW_StatusLabel</Pieces>
		<Pieces>AALW_CBP_Loot</Pieces>
		<Pieces>AALW_CBP_Discard</Pieces>
		<Pieces>AALW_CBP_AlwaysKeep</Pieces>
		<Pieces>AALW_CBP_Never</Pieces>
	</Screen>

