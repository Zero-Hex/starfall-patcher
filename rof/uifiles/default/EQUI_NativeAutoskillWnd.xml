<?xml version="1.0"?>
<XML ID="EQInterfaceDefinitionLanguage">
	<Schema xmlns="EverQuestData" xmlns:dt="EverQuestDataTypes" />

	<!-- Autoskill window: one row per combat skill #autoskill can toggle
	     automatic use of (see zone/autoskill_table.h). Click a row to toggle
	     it — green "ON" / red "OFF" / gray "N/A" (not usable for this
	     class/level) — same SIDL + WndNotification pattern as every other
	     native window in this repo. No icon column (these are skills, not
	     items); the Status cell IS the toggle button, colored via
	     ListSetCellColor exactly like the Celestial Bank's rows, since
	     there's no verified primitive to recolor a standalone Button's text
	     at runtime on this client build. -->

	<Listbox item="ASKW_ItemList">
		<ScreenID>ASKW_ItemList</ScreenID>
		<DrawTemplate>WDT_Inner</DrawTemplate>
		<TooltipReference>Click a row to toggle automatic use of that skill. Green ON = enabled, Red OFF = disabled, Gray N/A = not usable for your class/level right now.</TooltipReference>
		<RelativePosition>true</RelativePosition>
		<Location><X>10</X><Y>32</Y></Location>
		<Size><CX>240</CX><CY>220</CY></Size>
		<Style_Border>true</Style_Border>
		<Style_VScroll>true</Style_VScroll>
		<Columns><Width>150</Width><Heading>Skill</Heading></Columns>
		<Columns><Width>70</Width><Heading>Status</Heading></Columns>
	</Listbox>

	<Button item="ASKW_RefreshButton">
		<ScreenID>ASKW_RefreshButton</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>10</X><Y>262</Y></Location>
		<Size><CX>80</CX><CY>24</CY></Size>
		<Text>Refresh</Text>
		<TextColor><R>255</R><G>255</G><B>255</B></TextColor>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>false</Style_Checkbox>
		<Template>BDT_Normal</Template>
	</Button>

	<Label item="ASKW_StatusLabel">
		<ScreenID>ASKW_StatusLabel</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>10</X><Y>292</Y></Location>
		<Size><CX>240</CX><CY>20</CY></Size>
		<Text></Text>
		<TextColor><R>190</R><G>210</G><B>230</B></TextColor>
		<NoWrap>false</NoWrap>
	</Label>

	<Screen item="NativeAutoskillWnd">
		<ScreenID>NativeAutoskillWnd</ScreenID>
		<RelativePosition>false</RelativePosition>
		<Location><X>140</X><Y>80</Y></Location>
		<Size><CX>260</CX><CY>345</CY></Size>
		<Text>Autoskill</Text>
		<DrawTemplate>WDT_Def</DrawTemplate>
		<Style_Titlebar>true</Style_Titlebar>
		<Style_Closebox>true</Style_Closebox>
		<Style_Minimizebox>true</Style_Minimizebox>
		<Style_Border>true</Style_Border>
		<Style_Sizable>false</Style_Sizable>
		<Style_Transparent>false</Style_Transparent>
		<Pieces>ASKW_ItemList</Pieces>
		<Pieces>ASKW_RefreshButton</Pieces>
		<Pieces>ASKW_StatusLabel</Pieces>
	</Screen>

</XML>
