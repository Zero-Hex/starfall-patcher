<?xml version="1.0"?>
<XML ID="EQInterfaceDefinitionLanguage">
	<Schema xmlns="EverQuestData" xmlns:dt="EverQuestDataTypes" />

	<!-- Native Help / Reference window. Two panels, not three: Topics render
	     as children directly under their category in HELPW_CategoryList
	     (simulated tree, same as Achievements'/Collections' category lists,
	     since CListWnd has no native indent/expand support), which frees the
	     whole right side for the Details panel instead of splitting it with
	     a separate Topics list. Non-sizable (like the original Achievements
	     window) since nothing here needs to grow on resize; no
	     ReflowIfResized required client-side. -->

	<Screen item="HELPW_SummaryPanel">
		<ScreenID>HELPW_SummaryPanel</ScreenID>
		<DrawTemplate>WDT_RoundedNoTitle</DrawTemplate>
		<RelativePosition>true</RelativePosition>
		<Location><X>12</X><Y>10</Y></Location>
		<Size><CX>816</CX><CY>76</CY></Size>
		<Style_Titlebar>false</Style_Titlebar>
		<Style_Minimizebox>false</Style_Minimizebox>
		<Style_Border>true</Style_Border>
		<Style_Transparent>false</Style_Transparent>
		<Style_Sizable>false</Style_Sizable>
		<Style_Closebox>false</Style_Closebox>
	</Screen>

	<Label item="HELPW_SummaryTitleLabel">
		<ScreenID>HELPW_SummaryTitleLabel</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location><X>26</X><Y>18</Y></Location>
		<Size><CX>300</CX><CY>18</CY></Size>
		<Text>Help &amp; Reference</Text>
		<Font>3</Font>
		<TextColor><R>248</R><G>189</G><B>33</B></TextColor>
		<NoWrap>true</NoWrap>
	</Label>

